# =========================================================================
# College FAQ Chatbot - Global Environment Configurations (.env)
# =========================================================================

# ----------------------------------------------------
# 1. JWT Security Settings
# ----------------------------------------------------
SECRET_KEY=your_jwt_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ----------------------------------------------------
# 2. Database Connection (Neon PostgreSQL / Cloud DB)
# ----------------------------------------------------
DATABASE_URL=postgresql://username:password@ep-host-name.region.aws.neon.tech/dbname

# ----------------------------------------------------
# 3. Vector Database Configuration (Qdrant Cloud)
# ----------------------------------------------------
QDRANT_URL=https://your-qdrant-cluster-url.aws.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_cloud_api_key_here
QDRANT_COLLECTION_NAME=college_faq_collection

# ----------------------------------------------------
# 4. LLM API Key (Groq Cloud API)
# ----------------------------------------------------
GROQ_API_KEY=gsk_your_groq_api_key_here

# ----------------------------------------------------
# 5. Frontend API Configuration
# ----------------------------------------------------
# Set this to the public IP or domain of your EC2 instance (e.g., http://54.23.45.67:8000)
# Make sure to include the http:// prefix and the backend port (8000).
VITE_API_URL=http://localhost:8000

# ----------------------------------------------------
# 6. Storage Settings (AWS S3 or Local fallbacks)
# ----------------------------------------------------
USE_S3_STORAGE=false

# Fill these in ONLY if USE_S3_STORAGE is set to 'true':
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=your_s3_bucket_name
